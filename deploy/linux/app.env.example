# 应用运行时环境变量。被 doc-review.service 的 EnvironmentFile 加载。
# 部署时修改此文件中的密码/密钥,然后 chmod 600 + chown docreview:docreview

# 数据库连接(覆盖 config.json):
DATABASE_URL=postgresql://docreview:please_change_me@127.0.0.1:5432/doc_review

# CORS:生产同源不需要;若业务方独立域名调用,改成具体 origin 列表
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com

# 调优(稳定优先,4C/8G 单盘机器建议保持以下默认值)
UPLOAD_CONCURRENCY=1
ARCHIVE_DETECT_MAX_FILES_PER_BATCH=50
# ARCHIVE_DETECT_QUEUE_MAX=300
